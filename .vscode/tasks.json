{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run MATLAB (batch)",
            "type": "shell",
            "command": "matlab -batch \"run('main.m')\"",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        }
    ]
}